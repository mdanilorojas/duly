{
  "name": "@enregla-ui/duly-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "React UI components for the Studio design system — accessible, themeable, Tailwind v4, RSC-ready.",
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwindcss",
    "accessible",
    "rsc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdanilorojas/duly.git",
    "directory": "packages/ui"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./reset.css": "./dist/reset.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.57",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@internationalized/date": "^3.12.2",
    "@mcp-ui/client": "^7.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@stepperize/react": "^7.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.451.0",
    "radix-ui": "^1.6.1",
    "react-aria-components": "^1.19.0",
    "react-hook-form": "^7.54.0",
    "recharts": "^3.9.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@duly/eslint-config": "workspace:*",
    "@duly/tsconfig": "workspace:*",
    "@enregla-ui/duly-tokens": "workspace:*",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest-axe": "^3.5.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.13.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
