{
  "name": "@duly/tokens",
  "version": "0.0.0",
  "type": "module",
  "description": "Design tokens for the Studio design system — themeable CSS variables (hex + oklch) and typed JS token maps.",
  "keywords": ["design-tokens", "design-system", "css-variables", "tailwindcss", "theme", "oklch"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdanilorojas/duly.git",
    "directory": "packages/tokens"
  },
  "module": "./dist/tokens.js",
  "types": "./dist/tokens.d.ts",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/tokens.d.ts", "import": "./dist/tokens.js" },
    "./css": "./dist/index.css",
    "./theme.css": "./dist/theme.css",
    "./motion.css": "./dist/motion.css",
    "./theme-cockpit.css": "./dist/theme-cockpit.css",
    "./theme-light.css": "./dist/theme-light.css",
    "./theme-violet.css": "./dist/theme-violet.css"
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "tokens": "tsx build.ts",
    "build": "echo 'dist already generated by tokens task'",
    "prepublishOnly": "pnpm run tokens",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "@duly/tsconfig": "workspace:*",
    "@duly/eslint-config": "workspace:*",
    "eslint": "^9.13.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "culori": "^4.0.1",
    "typescript": "^5.6.0"
  }
}
