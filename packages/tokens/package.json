{
  "name": "@studio/tokens",
  "version": "0.0.0",
  "type": "module",
  "description": "Design tokens for the Studio design system — themeable CSS variables (hex + oklch) and typed JS token maps.",
  "keywords": ["design-tokens", "design-system", "css-variables", "tailwindcss", "theme", "oklch"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studio/design-system",
    "directory": "packages/tokens"
  },
  "module": "./dist/tokens.js",
  "types": "./dist/tokens.d.ts",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/tokens.d.ts", "import": "./dist/tokens.js" },
    "./css": "./dist/index.css",
    "./theme.css": "./dist/theme.css",
    "./theme-cockpit.css": "./dist/theme-cockpit.css",
    "./theme-test.css": "./dist/theme-test.css"
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "tokens": "tsx build.ts",
    "build": "tsx build.ts",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "@studio/tsconfig": "workspace:*",
    "@studio/eslint-config": "workspace:*",
    "eslint": "^9.13.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "culori": "^4.0.1",
    "typescript": "^5.6.0"
  }
}
