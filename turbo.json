{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "tokens": { "inputs": ["build.ts", "src/**"], "outputs": ["dist/**"] },
    "build": { "dependsOn": ["^build", "tokens"], "outputs": ["dist/**", "storybook-static/**"] },
    "lint": {},
    "test": { "dependsOn": ["tokens"] }
  }
}
